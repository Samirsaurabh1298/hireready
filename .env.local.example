# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep this secret, never expose to client

# ── Resend ────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── App config ────────────────────────────────────────────────────
TEAM_EMAIL=support@hireready.in   # where new application alerts go
